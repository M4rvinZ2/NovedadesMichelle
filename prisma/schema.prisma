generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  nombre    String
  rol       String   @default("EMPLEADO")
  createdAt DateTime @default(now())
}

model Producto {
  id           Int       @id @default(autoincrement())
  nombre       String
  precio       Float
  stock        Int       @default(0)
  codigoBarras String?   @unique
  proveedorId  Int?
  proveedor    Proveedor? @relation(fields: [proveedorId], references: [id])
  ventaItems   VentaItem[]
  compraItems  CompraItem[]
  movimientos  MovimientoInventario[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Proveedor {
  id        Int       @id @default(autoincrement())
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  productos Producto[]
  compras   Compra[]
  createdAt DateTime  @default(now())
}

model Empleado {
  id          Int          @id @default(autoincrement())
  codigo      String       @unique
  nombre      String
  puesto      String?
  asistencias Asistencia[]
  ventas      Venta[]
  createdAt   DateTime     @default(now())
}

model Asistencia {
  id         Int       @id @default(autoincrement())
  empleadoId Int
  empleado   Empleado  @relation(fields: [empleadoId], references: [id])
  tipo       String
  fecha      DateTime  @default(now())
}

model Venta {
  id         Int         @id @default(autoincrement())
  total      Float
  vendedorId Int?
  vendedor   Empleado?   @relation(fields: [vendedorId], references: [id])
  items      VentaItem[]
  createdAt  DateTime    @default(now())
}

model VentaItem {
  id         Int      @id @default(autoincrement())
  ventaId    Int
  venta      Venta    @relation(fields: [ventaId], references: [id])
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])
  cantidad   Int
  precioUnit Float
}

model MovimientoInventario {
  id         Int      @id @default(autoincrement())
  tipo       String
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])
  cantidad   Int
  motivo     String?
  createdAt  DateTime @default(now())
}

model MovimientoCaja {
  id         Int      @id @default(autoincrement())
  tipo       String
  monto      Float
  concepto   String
  referencia String?
  createdAt  DateTime @default(now())
}

model Compra {
  id          Int         @id @default(autoincrement())
  proveedorId Int
  proveedor   Proveedor   @relation(fields: [proveedorId], references: [id])
  total       Float
  items       CompraItem[]
  createdAt   DateTime    @default(now())
}

model CompraItem {
  id         Int      @id @default(autoincrement())
  compraId   Int
  compra     Compra   @relation(fields: [compraId], references: [id])
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])
  cantidad   Int
  precioUnit Float
}
